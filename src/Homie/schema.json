{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "系统": {
      "default": {},
      "type": "object",
      "properties": {
        "日期": {
          "default": "2026/07/08",
          "type": "string"
        },
        "时间段": {
          "default": "下午",
          "type": "string"
        },
        "当前场景": {
          "default": "合租公寓",
          "type": "string"
        },
        "今日安排": {
          "default": "",
          "type": "string"
        }
      }
    },
    "Jake": {
      "default": {},
      "type": "object",
      "properties": {
        "关系阶段": {
          "default": "重逢期",
          "type": "string",
          "enum": [
            "重逢期",
            "挣扎期",
            "面对期"
          ]
        },
        "觉察度": {
          "default": 0,
          "type": "number"
        },
        "冷热状态": {
          "default": "正常",
          "type": "string",
          "enum": [
            "热",
            "正常",
            "冷"
          ]
        },
        "对user的依赖度": {
          "default": 10,
          "type": "number"
        },
        "订阅数": {
          "default": 480000,
          "type": "number"
        },
        "直播状态": {
          "default": "今日不播",
          "type": "string",
          "enum": [
            "直播中",
            "未开播",
            "已下播",
            "今日不播"
          ]
        }
      }
    },
    "user": {
      "default": {},
      "type": "object",
      "properties": {
        "疲惫值": {
          "default": 0,
          "type": "number"
        },
        "离开决心": {
          "default": 0,
          "type": "number"
        },
        "SNS粉丝数": {
          "default": 2300,
          "type": "number"
        },
        "委托": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "客户": {
                "default": "",
                "type": "string"
              },
              "内容": {
                "default": "",
                "type": "string"
              },
              "类型": {
                "default": "个人委托",
                "type": "string",
                "enum": [
                  "商稿",
                  "个人委托",
                  "Jake直播间"
                ]
              },
              "酬劳": {
                "default": 0,
                "type": "number"
              },
              "截稿日": {
                "default": "",
                "type": "string"
              },
              "状态": {
                "default": "进行中",
                "type": "string",
                "enum": [
                  "进行中",
                  "已完成",
                  "已逾期",
                  "已取消"
                ]
              }
            }
          }
        }
      }
    },
    "日程": {
      "default": {},
      "type": "object",
      "properties": {
        "本周特殊事项": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "UID计数器": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "number"
      }
    }
  }
}